---
import { signaturePaths, SIGNATURE_VIEWBOX, SIGNATURE_FONT_SIZE } from './signaturePaths.generated';

interface Props {
	name: string;
}

const { name } = Astro.props;
const viewBoxAttr = `${SIGNATURE_VIEWBOX.minX} ${SIGNATURE_VIEWBOX.minY} ${SIGNATURE_VIEWBOX.width} ${SIGNATURE_VIEWBOX.height}`;
// Ratio between the glyphs' ink height and the font-size used to generate them —
// scales the SVG so it visually matches the old font-size-based letter size
// instead of being clamped to the (much smaller) raw ink bounding box.
const emScale = (SIGNATURE_VIEWBOX.height / SIGNATURE_FONT_SIZE).toFixed(3);
---

<span class="name handwriting fade-seq-2">
	<svg class="signature-svg" viewBox={viewBoxAttr} style={`--signature-em-scale:${emScale};`} aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
		{signaturePaths.map((letter, index) => (
			<g class="signature-letter-group" style={`--letter-index:${index};`} data-char={letter.char}>
				<mask id={`signature-fill-mask-${index}`}>
					<path class="signature-mask-stroke" d={letter.d} />
				</mask>
				<path class="signature-fill" d={letter.d} mask={`url(#signature-fill-mask-${index})`} />
				<path class="signature-stroke" d={letter.d} />
			</g>
		))}
	</svg>
	<span class="signature-fallback" aria-label={name}>{name}</span>
</span>

<script>
	const dashPaths = document.querySelectorAll<SVGPathElement>('.signature-stroke, .signature-mask-stroke');
	dashPaths.forEach((path) => {
		const length = path.getTotalLength();
		path.style.strokeDasharray = String(length);
		path.style.strokeDashoffset = String(length);
	});
	document.querySelectorAll('.signature-svg').forEach((svg) => svg.classList.add('svg-ready'));
</script>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Pacifico&display=swap');

	.name {
		font-size: 4.5rem;
		font-weight: 600;
		color: #1a1a1a;
		letter-spacing: 0.02em;
		line-height: 1.2;
	}

	.handwriting {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		font-style: italic;
	}

	.signature-svg {
		height: calc(clamp(2.5rem, 6vw, 4.5rem) * var(--signature-em-scale));
		width: auto;
		display: block;
		overflow: visible;
	}

	.signature-fill {
		fill: #1a1a1a;
		stroke: none;
	}

	/* Invisible, oversized copy of the same path used purely as a mask: as it
	   draws (identical stroke-dasharray/dashoffset animation as the visible
	   line below), it reveals the fill along the exact geometry the line is
	   tracing, instead of a straight/circular approximation — so the ink
	   genuinely follows the stroke's real path instead of racing ahead of or
	   lagging behind it in curvy areas. */
	.signature-mask-stroke {
		fill: none;
		stroke: #fff;
		stroke-width: 70;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.signature-stroke {
		fill: none;
		stroke: #1a1a1a;
		stroke-width: 4;
		stroke-linecap: round;
		stroke-linejoin: round;
		opacity: 0;
	}

	.signature-fallback {
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		font-family: 'Pacifico', 'Hiragino Sans GB', cursive;
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		font-style: italic;
		opacity: 0;
		pointer-events: none;
	}

	:global(.page-ready) .signature-svg.svg-ready .signature-stroke,
	:global(.page-ready) .signature-svg.svg-ready .signature-mask-stroke {
		animation: strokeDraw 0.55s cubic-bezier(0.65, 0, 0.35, 1) forwards;
		animation-delay: calc(0.6s + var(--letter-index) * 0.18s);
	}

	:global(.page-ready) .signature-svg.svg-ready .signature-stroke {
		opacity: 1;
	}

	@keyframes strokeDraw {
		to {
			stroke-dashoffset: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.signature-fill {
			mask: none !important;
		}
		.signature-stroke {
			animation: none !important;
			opacity: 1 !important;
			stroke-dashoffset: 0 !important;
		}
	}

	@media (max-width: 768px) {
		.name {
			font-size: 3rem;
		}
	}

	@media (max-width: 480px) {
		.name {
			font-size: 2.5rem;
		}
	}
</style>

